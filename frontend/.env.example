# WalletConnect / Reown project id (free at cloud.reown.com).
# Enables Freighter mobile + LOBSTR + others from Android Chrome (keeps the
# user in Chrome so Web NFC still works). Leave blank to use extension wallets only.
VITE_WALLETCONNECT_PROJECT_ID=

# Stellar network — testnet (default for development)
VITE_STELLAR_NETWORK=testnet
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Deployed factory (Testnet — multi-token). Vaults hold any Stellar asset;
# tokens register on deposit, so no single token id is needed.
VITE_FACTORY_CONTRACT_ID=CANQJ6N5BNPYY5CZWGRY7QTZKAY7IAIMSI7RPRNJZP564DROBWOG5PQM

# PDAX fiat rails (server-only — never expose to client). Auth is
# username/password against the UAT sandbox; see docs/PDAX_API.md.
PDAX_USERNAME=
PDAX_PASSWORD=
PDAX_BASE_URL=https://uat.services.sandbox.pdax.ph/api/pdax-api
RAMP_RATE_FALLBACK=58

# RWA compliance approver (Phase 3, api/kyc.ts) and redemption custodian
# (Phase 4, api/redeem.ts) — server-only, stand in for a licensed operator.
# See docs/RWA_PHASES.md.
RWA_ISSUER_SECRET=
RWA_GATED_ISSUER_SECRET=

# Web Push (check-in reminders — demo only, subscriptions are in-memory and
# reset on redeploy; see api/_push.ts). Generate with:
#   npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@pamana.app
